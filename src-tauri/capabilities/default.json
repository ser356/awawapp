{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-open",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "vlc",
          "cmd": "/Applications/VLC.app/Contents/MacOS/VLC",
          "args": true
        },
        {
          "name": "open",
          "cmd": "open",
          "args": ["-a", "VLC", { "validator": "\\S+" }]
        }
      ]
    }
  ]
}
